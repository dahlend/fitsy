    def append(self, value: Union[Hdu, Builder]) -> None: ...
    def insert(self, index: int, value: Union[Hdu, Builder]) -> None: ...
    def hdu(self, index: int) -> Hdu: ...
    def hdu_by_name(self, name: str, ver: Optional[int] = None) -> Hdu: ...
    def wcs(self, index: int = 0, alt: str = " ") -> Optional[Wcs]: ...
    def writeto(self, path: StrPath, overwrite: bool = False) -> None: ...
    def verify_checksums(self) -> list[dict[str, Optional[bool] | int]]: ...
    def add_checksums(self) -> None: ...
