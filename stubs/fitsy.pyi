# Path-like accepted by IO functions.
StrPath = Union[str, PathLike[str]]

# Scalar value types appearing in headers.
HeaderScalar = Union[bool, int, float, complex, str, None]

class FitsError(OSError):
    """Base class for all FITS-related errors raised by :mod:`fitsy`."""

class Header:
    """Dict-like view of a FITS header. See :class:`fitsy.Header` docs."""

    @property
    def read_only(self) -> bool: ...
    def __contains__(self, key: str) -> bool: ...
    def __getitem__(
        self, key: Union[str, tuple[str, int]]
    ) -> Union[HeaderScalar, "HeaderCommentary"]: ...
    def __setitem__(
        self,
        key: str,
        value: Union[HeaderScalar, tuple[HeaderScalar, Optional[str]]],
    ) -> None: ...
    def __delitem__(self, key: str) -> None: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> Iterator[str]: ...
    def add_commentary(self, kind: str, text: str) -> None: ...
    def update(self, other: Union["Header", Mapping[str, Any]]) -> None: ...
    def get(self, key: str, default: Any = ...) -> Any: ...
    def keys(self) -> list[str]: ...
    def items(self) -> list[tuple[str, HeaderScalar]]: ...
    def comment(self, key: str) -> Optional[str]: ...
    def cards(self, key: str) -> list[tuple[Any, Optional[str]]]: ...
    def to_dict(self) -> dict[str, HeaderScalar]: ...
    def tostring(self) -> str: ...
    def __bytes__(self) -> bytes: ...
    def set(
        self,
        keyword: str,
        value: HeaderScalar = None,
