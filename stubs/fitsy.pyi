    def rename_keyword(self, oldname: str, newname: str) -> None: ...

class HeaderCommentary:
    """List-like view of repeated commentary cards (COMMENT, HISTORY, blank)."""

    def __len__(self) -> int: ...
    def __getitem__(self, idx: int) -> str: ...
    def __iter__(self) -> Iterator[str]: ...
    def __str__(self) -> str: ...

class ImageHdu:
    """Image HDU. Construct from a numpy array, or get from :meth:`FitsFile.hdu`."""

    def __init__(
        self,
        data: np.ndarray,
        header: Optional[Union[Header, Mapping[str, Any]]] = None,
        name: Optional[str] = None,
    ) -> None: ...
    @property
    def header(self) -> Header: ...
    @property
    def axes(self) -> list[int]: ...
    @property
    def bitpix(self) -> int: ...
    @property
    def data(self) -> Optional[np.ndarray]: ...
    @data.setter
    def data(self, value: Optional[np.ndarray]) -> None: ...
    @property
    def section(self) -> "_ImageSection": ...
    def wcs(self, alt: str = " ") -> Optional[Wcs]: ...

class _ImageSection:
    """Lazy slicing view over an :class:`ImageHdu` data array.

    Internal type. Acquire instances via :attr:`ImageHdu.section`;
    do not construct directly. The leading underscore signals that
    the class itself is not part of the public API surface, only the
    ``__getitem__`` / ``__setitem__`` protocol it implements is.

    For files opened with ``mode='update'``, ``section[key] = value``
    writes only the affected pixel bytes to disk via positional
    ``pwrite`` -- O(patch) work, no full-image rewrite.
    """

    def __getitem__(self, key: Any) -> np.ndarray: ...
    def __setitem__(self, key: Any, value: Any) -> None: ...
    def __repr__(self) -> str: ...

